generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StudioType {
  DOCUMENT
}

enum DocumentStatus {
  UPLOADED
  PARSING_PENDING
  PARSED
  FAILED
}

enum ExtractedTextStatus {
  NOT_STARTED
  PROCESSING
  COMPLETED
  FAILED
  UNSUPPORTED
}

enum RuleCategory {
  EXTRACTION
  APPLICABILITY
  FORMAT
  VALIDATION
  OTHER
}

enum RuleSource {
  HUMAN
  AI_SUGGESTED
  SYSTEM
}

enum FeedbackEventType {
  ANNOTATION_CREATED
  ANNOTATION_UPDATED
  ANNOTATION_DELETED
  ANNOTATION_RULE_LINKED
  ANNOTATION_RULE_UNLINKED
  RULE_CREATED
  RULE_DELETED
  DOCUMENT_UPLOADED
  TEXT_EXTRACTED
  CORRECTION_ADDED
  TRAINING_CANDIDATE_CREATED
  TRAINING_CANDIDATE_APPROVED
  TRAINING_CANDIDATE_REJECTED
  AI_SUGGESTION_CREATED
  AI_SUGGESTION_APPROVED
  AI_SUGGESTION_REJECTED
  AI_SUGGESTION_EDITED
  AI_SUGGESTION_CONVERTED_TO_ANNOTATION
  VALIDATION_RUN_CREATED
  VALIDATION_RUN_COMPLETED
}

enum AiSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
  CONVERTED_TO_ANNOTATION
}

enum SuggestionMode {
  EXTRACTION
  DOCUMENT_CLASSIFICATION
}

enum ValidationRunMode {
  DOCUMENT_CLASSIFICATION
}

enum ValidationRunStatus {
  DRAFT
  RUNNING
  COMPLETED
  CANCELLED
}

enum ValidationRunItemStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

enum TrainingCandidateType {
  EXTRACTION
  APPLICABILITY_REJECTION
  FORMAT_CORRECTION
  VALIDATION_RULE
  OTHER
}

enum TrainingCandidateStatus {
  DRAFT
  REVIEWED
  APPROVED
  REJECTED
}

model Workspace {
  id                 String               @id @default(uuid())
  name               String
  description        String?
  studioType         StudioType
  documents          Document[]
  annotations        Annotation[]
  operationalRules   OperationalRule[]
  annotationLinks    AnnotationRuleLink[]
  trainingCandidates TrainingCandidate[]
  aiSuggestions      AiSuggestion[]
  validationRuns     ValidationRun[]
  feedbackEvents     FeedbackEvent[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([createdAt])
}

model Document {
  id                  String              @id @default(uuid())
  workspaceId         String
  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  originalName        String
  fileName            String
  mimeType            String
  size                Int
  filePath            String
  status              DocumentStatus
  extractedText       String?
  extractedTextStatus ExtractedTextStatus @default(NOT_STARTED)
  extractionError     String?
  annotations         Annotation[]
  trainingCandidates  TrainingCandidate[]
  aiSuggestions       AiSuggestion[]
  validationRunItems  ValidationRunItem[]
  feedbackEvents      FeedbackEvent[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([workspaceId, createdAt])
}

model Annotation {
  id                 String               @id @default(uuid())
  workspaceId        String
  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documentId         String
  document           Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ruleLinks          AnnotationRuleLink[]
  trainingCandidates TrainingCandidate[]
  aiSuggestions      AiSuggestion[]
  feedbackEvents     FeedbackEvent[]
  fieldName          String
  selectedText       String               @db.Text
  explanation        String?              @db.Text
  startOffset        Int?
  endOffset          Int?
  contextBefore      String?              @db.Text
  contextAfter       String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([workspaceId, createdAt])
  @@index([documentId, createdAt])
}

model AiSuggestion {
  id                    String             @id @default(uuid())
  workspaceId           String
  workspace             Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documentId            String
  document              Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  annotationId          String?
  annotation            Annotation?        @relation(fields: [annotationId], references: [id], onDelete: SetNull)
  fieldName             String
  selectedText          String             @db.Text
  reasoning             String             @db.Text
  confidence            Float
  mode                  SuggestionMode     @default(EXTRACTION)
  payloadJson           Json               @default("{}")
  status                AiSuggestionStatus @default(PENDING)
  correctedFieldName    String?
  correctedSelectedText String?            @db.Text
  correctedReasoning    String?            @db.Text
  correctedPayloadJson  Json?
  validationRunItems    ValidationRunItem[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([workspaceId, createdAt])
  @@index([documentId, createdAt])
  @@index([mode, createdAt])
  @@index([status, createdAt])
}

model OperationalRule {
  id              String               @id @default(uuid())
  workspaceId     String
  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  annotationLinks AnnotationRuleLink[]
  title           String
  ruleText        String               @db.Text
  category        RuleCategory
  source          RuleSource           @default(HUMAN)
  confidence      Float                @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([workspaceId, createdAt])
}

model ValidationRun {
  id             String              @id @default(uuid())
  workspaceId    String
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String
  description    String?             @db.Text
  mode           ValidationRunMode
  status         ValidationRunStatus  @default(DRAFT)
  totalItems     Int                  @default(0)
  approvedCount  Int                  @default(0)
  rejectedCount  Int                  @default(0)
  editedCount    Int                  @default(0)
  correctionRate Float                @default(0)
  approvalRate   Float                @default(0)
  startedAt      DateTime             @default(now())
  completedAt    DateTime?
  items          ValidationRunItem[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([workspaceId, createdAt])
  @@index([status, createdAt])
}

model ValidationRunItem {
  id              String                  @id @default(uuid())
  validationRunId String
  validationRun   ValidationRun           @relation(fields: [validationRunId], references: [id], onDelete: Cascade)
  documentId      String?
  document        Document?               @relation(fields: [documentId], references: [id], onDelete: SetNull)
  aiSuggestionId  String?
  aiSuggestion    AiSuggestion?           @relation(fields: [aiSuggestionId], references: [id], onDelete: SetNull)
  expectedLabel   String?
  predictedLabel  String?
  finalLabel      String?
  status          ValidationRunItemStatus @default(PENDING)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([validationRunId, createdAt])
  @@index([documentId, createdAt])
  @@index([aiSuggestionId, createdAt])
  @@index([status, createdAt])
}

model AnnotationRuleLink {
  id           String          @id @default(uuid())
  annotationId String
  annotation   Annotation      @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  ruleId       String
  rule         OperationalRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@unique([annotationId, ruleId])
  @@index([workspaceId, createdAt])
  @@index([annotationId, createdAt])
  @@index([ruleId, createdAt])
}

model TrainingCandidate {
  id             String                  @id @default(uuid())
  workspaceId    String
  workspace      Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documentId     String?
  document       Document?               @relation(fields: [documentId], references: [id], onDelete: SetNull)
  annotationId   String?
  annotation     Annotation?             @relation(fields: [annotationId], references: [id], onDelete: SetNull)
  candidateType  TrainingCandidateType
  inputText      String                  @db.Text
  expectedOutput Json
  instruction    String                  @db.Text
  reasoning      String?                 @db.Text
  status         TrainingCandidateStatus @default(DRAFT)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([workspaceId, createdAt])
  @@index([documentId, createdAt])
  @@index([annotationId, createdAt])
  @@index([status, createdAt])
}

model FeedbackEvent {
  id           String            @id @default(uuid())
  workspaceId  String
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documentId   String?
  document     Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)
  annotationId String?
  annotation   Annotation?       @relation(fields: [annotationId], references: [id], onDelete: SetNull)
  eventType    FeedbackEventType
  payloadJson  Json
  createdAt    DateTime          @default(now())

  @@index([workspaceId, createdAt])
  @@index([documentId, createdAt])
  @@index([annotationId, createdAt])
}
